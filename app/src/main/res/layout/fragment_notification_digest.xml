<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activity"
            android:textSize="20sp"
            android:fontFamily="@font/courierprime"
            android:textColor="@color/text_primary"
            android:paddingBottom="16dp"
            />

        <TextView
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All clear."
            android:textSize="15sp"
            android:textColor="@color/text_muted"
            android:gravity="center"
            android:paddingVertical="48dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/tier1Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Important"
                android:textSize="14sp"
                android:textColor="@color/section_header"
                android:letterSpacing="0.05"
                android:paddingTop="24dp"
                android:paddingBottom="16dp"
                android:fontFamily="@font/courierprime"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tier1Recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tier2Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Updates"
                android:textSize="14sp"
                android:textColor="@color/section_header"
                android:letterSpacing="0.05"
                android:paddingTop="24dp"
                android:paddingBottom="16dp"
                android:fontFamily="@font/courierprime"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tier2Recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/tier3Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tier3Header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="More"
                android:textSize="14sp"
                android:textColor="@color/section_header"
                android:letterSpacing="0.05"
                android:paddingTop="24dp"
                android:paddingBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:fontFamily="@font/courierprime"/>


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tier3Recycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>

